# ============================================================
# ResearchIQ - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# Then edit .env and add your API key(s).

# Google Gemini API Key (Required)
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (free tier recommended: gemini-1.5-flash has 1500 RPD)
# Options: gemini-1.5-flash, gemini-2.0-flash, gemini-2.5-flash
GEMINI_MODEL=gemini-1.5-flash

# Semantic Scholar API Key (Optional — gives higher rate limits)
# Get from: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ── Defaults (usually no need to change) ─────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=research_papers
APP_TITLE=ResearchIQ
MAX_PAPERS_PER_QUERY=20
EMBEDDING_MODEL=all-MiniLM-L6-v2
LOG_LEVEL=INFO
LOG_FILE=./logs/research_iq.log
