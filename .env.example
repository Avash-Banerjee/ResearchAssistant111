# ============================================================
# Research Intelligence System - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values

# Google Gemini API Key (Required)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Semantic Scholar API Key (Optional - higher rate limits)
# Get from: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=research_papers

# Application Settings
APP_TITLE=ResearchIQ
MAX_PAPERS_PER_QUERY=20
EMBEDDING_MODEL=all-MiniLM-L6-v2
GEMINI_MODEL=gemini-1.5-flash

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/research_iq.log
